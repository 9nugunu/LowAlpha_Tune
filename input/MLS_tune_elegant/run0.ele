&run_setup
	lattice = mlsLA.lte,
	use_beamline = RING,
	p_central_mev = 629,
	default_order = 2,
&end



&twiss_output
        filename = "%s.twi",
        concat_order = 2,
        matched = 1
        radiation_integrals = 1
&end
&rf_setup
        harmonic = 80
        total_voltage = 500e3
&end


&run_control 
	n_steps = 1,
&end

&bunched_beam &end

&track &end

&save_lattice filename = %s.new &end
