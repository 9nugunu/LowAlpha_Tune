! Run with no noise

&run_setup
        lattice = <input>.new,
        use_beamline = RING,
        p_central_mev = 629,
        default_order = 3,
        wrap_around = 1,
	rootname=<output>
&end

&twiss_output 
   filename=%s.twi,
   radiation_integrals = 1,
   matched = 1,
&end

&alter_elements name=CAVITY, type=RFCA, item=PHASE, value=180 &end
&alter_elements name=*, type=CSBEN*, item=N_KICKS, value=60 &end
&alter_elements name=*, type=KQUAD*, item=N_KICKS, value=40 &end
&alter_elements name=*, type=KSEXT*, item=N_KICKS, value=40 &end

&alter_elements 
  name=MAL, item=DP, value=0.0001
&end

&run_control
        n_passes = 20000
&end


&bunched_beam
&end

&track 
&end

&save_lattice filename = %s.new &end
